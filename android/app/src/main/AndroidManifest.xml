<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.cts.emlak">

    <!-- Required Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" tools:node="remove"/>
    
    <!-- Location permissions with rationale -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION"/>
    <!-- Keeps the GPS service alive while the courier is on shift and the
         device is locked. WAKE_LOCK is requested by flutter_foreground_task;
         POST_NOTIFICATIONS is mandatory on Android 13+ for the persistent
         on-shift notification; RECEIVE_BOOT_COMPLETED lets us autoresume
         tracking after a reboot when the shift flag is still on. -->
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>

    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Hardware features - helps with Play Store filtering -->
    <uses-feature
        android:name="android.hardware.location"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.location.gps"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.location.network"
        android:required="false" />

    <application
        android:label="Nar24"
        android:icon="@mipmap/ic_launcher"
        android:name="${applicationName}">

        <!-- Firebase Analytics: opt out of advertising ID collection.
             We don't run ads in this app, so we both (a) strip the
             AD_ID permission via tools:node="remove" above, and (b)
             tell Analytics never to attempt AD ID collection. Without
             (b), Analytics tries to read the ID at runtime, fails the
             permission check, logs a warning, and Play Console flags
             the app as potentially collecting AD ID — which means it
             keeps prompting for an advertising-ID data-safety
             declaration on every release. -->
        <meta-data
            android:name="google_analytics_adid_collection_enabled"
            android:value="false" />
        <meta-data
            android:name="google_analytics_default_allow_ad_personalization_signals"
            android:value="false" />
        <meta-data
            android:name="google_analytics_default_allow_ad_storage"
            android:value="false" />
        <meta-data
            android:name="google_analytics_default_allow_ad_user_data"
            android:value="false" />

        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_notification"/>

        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="high_importance_channel" />

        <!-- Google Maps API Key - MOVE THIS TO A SECURE LOCATION -->
        <!-- Consider using environment variables or build-time injection -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="@string/google_maps_api_key" />

        <!-- Deep linking configuration -->
        <meta-data android:name="flutter_deeplinking_enabled" android:value="true" />

        <!-- Impeller disabled on Android: Adreno+Vulkan path corrupts texture
             uploads under sustained image load (product feed, banners), which
             showed up as "matrixy/glitchy" frames in image widgets that healed
             on backgrounding (surface destroyed → textures re-uploaded). Skia
             is stable for this workload. Revisit if Flutter ships an Impeller
             fix for Adreno texture upload races. -->
        <meta-data
            android:name="io.flutter.embedding.android.EnableImpeller"
            android:value="false" />
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <!-- Deep linking intent filters -->
            <intent-filter android:autoVerify="true" android:priority="1000">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="nar24app" />
            </intent-filter>

             <intent-filter android:autoVerify="true" android:priority="950">
        <action android:name="android.intent.action.VIEW" />
        <category android:name="android.intent.category.DEFAULT" />
        <category android:name="android.intent.category.BROWSABLE" />
        <data 
            android:scheme="https" 
            android:host="www.nar24.com"
            android:pathPrefix="/productdetail" />
    </intent-filter>

            <!-- High priority: Subdomain for shared links -->
            <intent-filter android:autoVerify="true" android:priority="900">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="app.nar24.com" />
            </intent-filter>

            <!-- Fallback: Original Firebase hosting -->
            <intent-filter android:autoVerify="true" android:priority="800">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="emlak-mobile-app.web.app" />
            </intent-filter>

            <!-- Main launcher intent -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Meta data for Firebase and Google Play services -->
        <meta-data android:name="flutterEmbedding" android:value="2" />
        <meta-data android:name="com.google.android.gms.version" android:value="@integer/google_play_services_version" />

        <!-- Courier location foreground service.
             The plugin declares the service itself, but Android 14+ requires
             `foregroundServiceType` to be pinned by the app. We override it
             here with `tools:replace` so the merged manifest ships with
             type=location, and set stopWithTask=false so swipe-closing the
             app doesn't kill GPS while the courier is still on shift. -->
        <service
            android:name="com.pravera.flutter_foreground_task.service.ForegroundService"
            android:foregroundServiceType="location"
            android:exported="false"
            android:stopWithTask="false"
            tools:replace="android:foregroundServiceType,android:stopWithTask" />
    </application>

    <!-- Package visibility settings for querying text processing activities -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        
        <!-- App scheme queries -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="nar24app" />
        </intent>
        
        <!-- Web scheme queries -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
    </queries>
</manifest>