                onClick={() => {
                  if (orderTab === "orders-food")
                    setFoodSubtab(sub.key as FoodPoolStatus);
                  else setMarketSubtab(sub.key as MarketPoolStatus);
                }}
                className={`px-2.5 py-1 rounded-full text-[10px] font-semibold transition-colors ${
                  active
                    ? "bg-orange-100 text-orange-700 border border-orange-200"
                    : "bg-gray-50 text-gray-500 border border-gray-100 hover:bg-gray-100"
                }`}
              >
                {sub.label}
              </button>
            );
          })}
          <div className="ml-auto text-[10px] text-gray-400">
            {isPoolTab ? (
              selectedPoolOrderId ? (
                <span className="text-emerald-600 font-semibold flex items-center gap-1">
                  <MousePointerClick className="w-3 h-3" /> Kurye seçin
                </span>
              ) : (
                "Atamak için bir siparişe tıklayın"
              )
            ) : (
              "Salt okunur"
            )}
          </div>
        </div>

        <div className="flex items-center h-[88px]">
          {/* Prev button */}
          <div className="flex-shrink-0 pl-2 pr-1 self-stretch flex items-center">
            {poolPage > 0 ? (
              <button
                onClick={handlePoolPrev}
                disabled={poolLoading}
                className="p-1.5 rounded-lg bg-gray-50 hover:bg-gray-100 border border-gray-200 text-gray-500 disabled:opacity-50 transition-colors"
              >
                <ChevronLeft className="w-3.5 h-3.5" />
              </button>
            ) : (
              <div className="w-8" />
            )}
          </div>

          {/* Scrollable cards */}
          <div className="flex-1 overflow-x-auto overflow-y-hidden">
            <div className="flex items-center gap-2.5 px-2 py-2 min-w-0">
              {poolLoading && poolOrders.length === 0 ? (
                <div className="flex items-center gap-2 px-4 py-3">
                  <div className="w-4 h-4 border-2 border-amber-200 border-t-amber-500 rounded-full animate-spin" />
                  <span className="text-[11px] text-gray-400">Yükleniyor…</span>
                </div>
              ) : poolOrders.length === 0 ? (
                <div className="flex items-center gap-2 px-4 py-3">
                  <CheckCircle2 className="w-4 h-4 text-emerald-400" />
                  <span className="text-[12px] text-gray-400 font-medium">
                    Sipariş yok
                  </span>
                </div>
              ) : (
                poolOrders.map((order) => (
                  <PoolOrderCard
                    key={order.id}
                    order={order}
                    assignable={isPoolTab}
                    isSelected={selectedPoolOrderId === order.id}
                    isAssignMode={
                      !!selectedPoolOrderId && selectedPoolOrderId !== order.id
                    }
                    onClick={() => {
                      if (!isPoolTab) return;
                      setSelectedPoolOrderId((prev) =>
                        prev === order.id ? null : order.id,
                      );
                    }}
                  />
                ))
              )}
            </div>
          </div>

          {/* Next button */}
          {poolHasMore && (
            <div className="flex-shrink-0 pr-2 pl-1 self-stretch flex items-center">
              <button
                onClick={handlePoolNext}
                disabled={poolLoading}
                className="p-2 rounded-xl bg-amber-50 hover:bg-amber-100 border border-amber-200 text-amber-600 disabled:opacity-50 transition-colors"
              >
                <ChevronRight className="w-4 h-4" />
              </button>
            </div>
          )}
        </div>

        {/* Loading overlay for page transitions */}
        {poolLoading && poolOrders.length > 0 && (
          <div className="absolute inset-0 bg-white/60 flex items-center justify-center pointer-events-none">
            <div className="w-5 h-5 border-2 border-amber-200 border-t-amber-500 rounded-full animate-spin" />
          </div>
        )}
      </div>
    </div>
  );
}
