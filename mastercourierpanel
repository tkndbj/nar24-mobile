// ─────────────────────────────────────────────────────────────────────────────
// OSRM SCHEDULER
//
// Bounds load on the self-hosted OSRM VM so it can't be overwhelmed regardless
// of fleet size. Three guarantees:
//   1. Per-courier debounce — rapid signature changes (assign → pickup →
//      deliver) collapse into one fetch per courier.
//   2. Global concurrency cap — at most N fetches in flight against OSRM at
//      any instant. Extras queue.
//   3. Per-courier cancellation — if a newer signature arrives while a fetch
//      is in flight, the stale fetch is aborted and its slot freed.
//
// Peak OSRM RPS is bounded to ~ maxConcurrent / avgLatencySeconds.
// ─────────────────────────────────────────────────────────────────────────────

interface OsrmTask {
  uid: string;
  run: (signal: AbortSignal) => Promise<void>;
}

class OsrmScheduler {
  private readonly debounceMs: number;
  private readonly maxConcurrent: number;

  private pendingTimers = new Map<string, ReturnType<typeof setTimeout>>();
  private queue: OsrmTask[] = [];
  private inFlight = new Map<string, AbortController>();
  private active = 0;
  private destroyed = false;

  constructor(opts: { debounceMs: number; maxConcurrent: number }) {
    this.debounceMs = opts.debounceMs;
    this.maxConcurrent = opts.maxConcurrent;
  }

  schedule(task: OsrmTask) {
    if (this.destroyed) return;
    const existing = this.pendingTimers.get(task.uid);
    if (existing) clearTimeout(existing);

    const t = setTimeout(() => {
      this.pendingTimers.delete(task.uid);
      this.enqueue(task);
    }, this.debounceMs);

    this.pendingTimers.set(task.uid, t);
  }

  cancel(uid: string) {
    const t = this.pendingTimers.get(uid);
    if (t) {
      clearTimeout(t);
      this.pendingTimers.delete(uid);
    }
    const ac = this.inFlight.get(uid);
    if (ac) {
      ac.abort();
      this.inFlight.delete(uid);
    }
    this.queue = this.queue.filter((q) => q.uid !== uid);
  }

  destroy() {
    this.destroyed = true;
    for (const t of this.pendingTimers.values()) clearTimeout(t);
    this.pendingTimers.clear();
    for (const ac of this.inFlight.values()) ac.abort();
    this.inFlight.clear();
    this.queue = [];
  }

  private enqueue(task: OsrmTask) {
    // Newer signature supersedes any in-flight fetch for the same courier.
    const live = this.inFlight.get(task.uid);
    if (live) live.abort();

    // Dedupe: replace a queued task for this uid rather than adding a second.
    const idx = this.queue.findIndex((q) => q.uid === task.uid);
    if (idx >= 0) this.queue[idx] = task;
    else this.queue.push(task);

    this.drain();
  }

  private drain() {
    while (this.active < this.maxConcurrent && this.queue.length > 0) {
      const task = this.queue.shift()!;
      this.runOne(task);
    }
  }

  private async runOne(task: OsrmTask) {
    this.active++;
    const ac = new AbortController();
    this.inFlight.set(task.uid, ac);

    try {
      await task.run(ac.signal);
    } catch (err) {
      if ((err as Error)?.name !== "AbortError") {
        console.warn(`[OSRM] route fetch failed for ${task.uid}:`, err);
      }
    } finally {
      this.active--;
      if (this.inFlight.get(task.uid) === ac) this.inFlight.delete(task.uid);
      this.drain();
    }
  }
}

