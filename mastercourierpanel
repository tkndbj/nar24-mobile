  recalculatedAt: Timestamp | null;
}

// ─── Constants ────────────────────────────────────────────────────────────────

const DAILY_PAGE = 30;

// ─── Helpers ──────────────────────────────────────────────────────────────────

function fmt(n: number): string {
  return n.toLocaleString("tr-TR", { maximumFractionDigits: 0 }) + " ₺";
}

function fmtCount(n: number): string {
  return n.toLocaleString("tr-TR");
}

function fmtTs(ts: Timestamp | null): string {
  if (!ts) return "—";
  return ts.toDate().toLocaleDateString("tr-TR", {
    day: "2-digit", month: "short", year: "numeric",
    hour: "2-digit", minute: "2-digit",
  });
}

function fmtDate(dateStr: string): string {
  const [y, m, d] = dateStr.split("-").map(Number);
  if (!y || !m || !d) return dateStr;
  return new Date(y, m - 1, d).toLocaleDateString("tr-TR", {
    weekday: "short", day: "numeric", month: "short", year: "numeric",
  });
}

function fmtAvgTime(ms: number, count: number): string {
  if (!ms || !count) return "—";
  const avg = Math.round(ms / count / 60000);
  if (avg < 60) return `${avg} dk`;
  return `${Math.floor(avg / 60)}s ${avg % 60}dk`;
}

function fmtAvgTimeMs(ms: number): string {
  if (!ms) return "—";
  const mins = Math.round(ms / 60000);
  if (mins < 60) return `${mins} dk`;
  return `${Math.floor(mins / 60)}s ${mins % 60}dk`;
}

function getInitials(name: string): string {
  return (name || "?")
    .split(" ")
    .slice(0, 2)
    .map((n) => n[0] ?? "")
    .join("")
    .toUpperCase();
}

function todayKey(): string {
  return new Intl.DateTimeFormat("en-CA", {
    timeZone: "Europe/Istanbul",
    year: "numeric", month: "2-digit", day: "2-digit",
  }).format(new Date());
}

function cashRatio(cash: number, total: number): string {
  if (!total) return "0%";
  return `%${Math.round((cash / total) * 100)}`;
}

const AVATAR_COLORS = [
  "bg-orange-500", "bg-emerald-500", "bg-blue-500", "bg-violet-500",
  "bg-rose-500", "bg-amber-500", "bg-teal-500", "bg-cyan-500",
];

function avatarColor(uid: string): string {
  const idx = (uid.charCodeAt(0) + uid.charCodeAt(uid.length - 1)) % AVATAR_COLORS.length;
  return AVATAR_COLORS[idx];
}

// ─── Sub-components ───────────────────────────────────────────────────────────

function Avatar({ name, uid, size = "md" }: { name: string; uid: string; size?: "sm" | "md" | "lg" }) {
  const sz = size === "sm" ? "w-7 h-7 text-[10px]" : size === "lg" ? "w-12 h-12 text-sm" : "w-9 h-9 text-xs";
  return (
    <div className={`${sz} ${avatarColor(uid)} rounded-full flex items-center justify-center text-white font-bold flex-shrink-0 select-none`}>
      {getInitials(name)}
    </div>
  );
}

