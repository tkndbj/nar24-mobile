function getTodayKey(): string {
  const d = new Date();
  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;
}

function getInitials(name: string): string {
  return (name || "?")
    .split(" ")
    .map((n) => n[0] ?? "")
    .join("")
    .toUpperCase()
    .slice(0, 2);
}

function timeSince(ms: number): string {
  if (!ms) return "—";
  const diff = Date.now() - ms;
  const s = Math.floor(diff / 1000);
  if (s < 60) return `${s}s ago`;
  const m = Math.floor(s / 60);
  if (m < 60) return `${m}m ago`;
  return `${Math.floor(m / 60)}h ago`;
}

function formatAvgTime(ms: number, count: number): string {
  if (!ms || !count) return "—";
  const avg = Math.round(ms / count / 60000);
  if (avg < 60) return `${avg}m`;
  return `${Math.floor(avg / 60)}h ${avg % 60}m`;
}

function formatOrderTime(ts: Timestamp): string {
  const d = ts.toDate();
  const h = String(d.getHours()).padStart(2, "0");
  const m = String(d.getMinutes()).padStart(2, "0");
  return `${h}:${m}`;
}

async function fetchRouteOSRM(
  stops: google.maps.LatLng[],
  signal?: AbortSignal,
): Promise<OSRMResult> {
  const empty: OSRMResult = {
    path: [],
    totalDurationSec: 0,
    totalDistanceM: 0,
    legDurations: [],
  };
  if (stops.length < 2) return empty;
  const coords = stops.map((s) => `${s.lng()},${s.lat()}`).join(";");
  const url = `https://osrm.nar24panel.com/route/v1/driving/${coords}?overview=full&geometries=geojson&steps=true`;

  // Two attempts with jittered backoff on 5xx / network error. 4xx is a
  // coding bug — no point retrying. Aborts propagate out immediately.
  const maxAttempts = 2;
  for (let attempt = 1; attempt <= maxAttempts; attempt++) {
    try {
      const res = await fetch(url, { signal });
      if (!res.ok) {
        if (res.status >= 500 && attempt < maxAttempts) {
          await new Promise((r) =>
            setTimeout(r, 300 * attempt + Math.random() * 200),
          );
          continue;
        }
        return empty;
      }
      const data = await res.json();
      if (data.code !== "Ok" || !data.routes?.[0]) return empty;

      const route = data.routes[0];
      const path = route.geometry.coordinates.map(
        ([lng, lat]: [number, number]) => new window.google.maps.LatLng(lat, lng),
      );
      const legDurations = route.legs.map(
        (leg: { duration: number }) => leg.duration,
      );
      return {
        path,
        totalDurationSec: route.duration,
        totalDistanceM: route.distance,
        legDurations,
      };
    } catch (err) {
      if ((err as Error).name === "AbortError") throw err;
      if (attempt < maxAttempts) {
        await new Promise((r) =>
          setTimeout(r, 300 * attempt + Math.random() * 200),
        );
        continue;
      }
      return empty;
    }
  }
  return empty;
}

const AVATAR_COLORS = [
  "bg-orange-500",
  "bg-emerald-500",
  "bg-blue-500",
  "bg-violet-500",
  "bg-rose-500",
  "bg-amber-500",
  "bg-teal-500",
  "bg-cyan-500",
];

function avatarColor(uid: string): string {
  const idx =
    (uid.charCodeAt(0) + uid.charCodeAt(uid.length - 1)) % AVATAR_COLORS.length;
  return AVATAR_COLORS[idx];
}

