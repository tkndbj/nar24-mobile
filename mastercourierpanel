// ─── Page ─────────────────────────────────────────────────────────────────────

export default function FoodAccountingPage() {
  const router = useRouter();

  // ── Auth ────────────────────────────────────────────────────────────────────
  const [authState, setAuthState] = useState<AuthState>("loading");

  // ── Category ────────────────────────────────────────────────────────────────
  const [category, setCategory] = useState<CategoryType>("yemek");

  // ── Tabs ────────────────────────────────────────────────────────────────────
  const [tab, setTab] = useState<PeriodType>("daily");

  // ── Calculate form ──────────────────────────────────────────────────────────
  const [selDate, setSelDate]     = useState(getYesterday());
  const [selYear, setSelYear]     = useState(getLastWeek().year);
  const [selWeek, setSelWeek]     = useState(getLastWeek().week);
  const [selMYear, setSelMYear]   = useState(getLastMonth().year);
  const [selMonth, setSelMonth]   = useState(getLastMonth().month);
  const [calcBusy, setCalcBusy]   = useState(false);
  const [calcMsg, setCalcMsg]     = useState<{ ok: boolean; text: string } | null>(null);

  // ── History list ────────────────────────────────────────────────────────────
  const [history, setHistory]         = useState<PeriodEntry[]>([]);
  const [histLoading, setHistLoading] = useState(false);
  const [histHasMore, setHistHasMore] = useState(false);
  const histCursorRef = useRef<QueryDocumentSnapshot<DocumentData> | null>(null);

  // ── Selected period ─────────────────────────────────────────────────────────
  const [selKey, setSelKey]               = useState<string | null>(null);
  const [platform, setPlatform]           = useState<AccountingDoc | null>(null);
  const [platLoading, setPlatLoading]     = useState(false);
  const [allRests, setAllRests]           = useState<AccountingDoc[]>([]);
  const [restsLoading, setRestsLoading]   = useState(false);
  const [restPage, setRestPage]           = useState(0);
  const [expandedRests, setExpandedRests] = useState<Set<string>>(new Set());
  const [expandedItems, setExpandedItems] = useState<Set<string>>(new Set());
  const selKeyRef = useRef<string | null>(null);

  // Keep selKeyRef in sync
  useEffect(() => { selKeyRef.current = selKey; }, [selKey]);

  // ── Auth check ───────────────────────────────────────────────────────────────
  useEffect(() => {
    return onAuthStateChanged(auth, async (user) => {
      if (!user) { setAuthState("denied"); return; }
      try {
        const t = await user.getIdTokenResult(true);
        const c = t.claims || {};
        setAuthState(
          c.isAdmin === true || c.masterCourier === true ? "allowed" : "denied",
        );
      } catch {
        setAuthState("denied");
      }
    });
  }, []);

  const activeTabRef = useRef<PeriodType>(tab);

  // ── Load history ─────────────────────────────────────────────────────────────
  const loadHistPage = useCallback(async (type: PeriodType, reset: boolean) => {
    activeTabRef.current = type;
    setHistLoading(true);
    try {
      const cursor = reset ? null : histCursorRef.current;
      const coll = collection(db, COLLS[category][type]);

      const q = category === "market"
        ? cursor
          ? query(
              coll,
              orderBy("periodKey", "desc"),
              startAfter(cursor),
              limit(HIST_LIMIT + 1),
            )
          : query(
              coll,
              orderBy("periodKey", "desc"),
              limit(HIST_LIMIT + 1),
            )
        : cursor
          ? query(
              coll,
              where("restaurantId", "==", "_PLATFORM"),
              orderBy("periodKey", "desc"),
              startAfter(cursor),
              limit(HIST_LIMIT + 1),
            )
          : query(
              coll,
              where("restaurantId", "==", "_PLATFORM"),
              orderBy("periodKey", "desc"),
              limit(HIST_LIMIT + 1),
            );

      const snap = await getDocs(q);
      if (activeTabRef.current !== type) return;
      const hasMore = snap.docs.length > HIST_LIMIT;
      const pageDocs = snap.docs.slice(0, HIST_LIMIT);

      if (hasMore && pageDocs.length > 0) {
        histCursorRef.current = pageDocs[pageDocs.length - 1];
      }

      const items: PeriodEntry[] = pageDocs.map((d) => {
        const data = d.data();
        return {
          docId: d.id,
          periodKey: (data.periodKey as string) || "",
          totalOrders: (data.totalOrders as number) || 0,
          grossRevenue: (data.grossRevenue as number) || 0,
          restaurantCount: (data.restaurantCount as number) || 0,
          calculatedAt: (data.calculatedAt as Timestamp) || null,
        };
      });

      setHistory((prev) => (reset ? items : [...prev, ...items]));
      setHistHasMore(hasMore);
    } catch (err) {
      console.error("[FoodAccounting] History load error:", err);
    } finally {
      setHistLoading(false);
    }
  }, [category]);

  // ── Reset on tab change ──────────────────────────────────────────────────────
  useEffect(() => {
    if (authState !== "allowed") return;
    histCursorRef.current = null;
    setHistory([]);
    setHistHasMore(false);
    setSelKey(null);
    setPlatform(null);
    setAllRests([]);
    setExpandedRests(new Set());
    setExpandedItems(new Set());
    setCalcMsg(null);
    loadHistPage(tab, true);
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [tab, category, authState]);

  // ── Select period ────────────────────────────────────────────────────────────
  const selectPeriod = useCallback(
    async (key: string) => {
      // Toggle off
      if (selKeyRef.current === key) {
        setSelKey(null);
        setPlatform(null);
        setAllRests([]);
        setExpandedRests(new Set());
        setExpandedItems(new Set());
        return;
      }

      setSelKey(key);
      setPlatform(null);
      setAllRests([]);
      setRestPage(0);
      setExpandedRests(new Set());
      setExpandedItems(new Set());

      const coll = COLLS[category][tab];
      const docPrefix = category === "market" ? "MARKET" : "PLATFORM";

      // 1. Load summary doc directly by ID
      setPlatLoading(true);
      try {
        const snap = await getDoc(doc(db, coll, `${docPrefix}_${key}`));
        if (snap.exists()) {
          setPlatform(snap.data() as AccountingDoc);
        }
      } catch (err) {
        console.error("[FoodAccounting] Platform doc error:", err);
      } finally {
        setPlatLoading(false);
      }

      // 2. Load all restaurant docs for this period (only for yemek — market has no restaurants)
      if (category === "yemek") {
        setRestsLoading(true);
        try {
          const q = query(
            collection(db, coll),
            where("periodKey", "==", key),
            limit(500),
          );
          const snap = await getDocs(q);
          const rests: AccountingDoc[] = [];
          snap.docs.forEach((d) => {
            const data = d.data() as AccountingDoc;
            if (data.restaurantId !== "_PLATFORM") {
              rests.push(data);
            }
          });
          rests.sort((a, b) => b.grossRevenue - a.grossRevenue);
          setAllRests(rests);
        } catch (err) {
          console.error("[FoodAccounting] Restaurants load error:", err);
        } finally {
          setRestsLoading(false);
        }
      }
    },
    [tab, category],
  );

  // ── Calculate ────────────────────────────────────────────────────────────────
  const handleCalculate = useCallback(async () => {
    setCalcBusy(true);
    setCalcMsg(null);

    let payload: Record<string, unknown> = {};
    let expectedKey = "";

    if (tab === "daily") {
      payload = { date: selDate };
      expectedKey = selDate;
    } else if (tab === "weekly") {
      payload = { year: selYear, week: selWeek };
      expectedKey = `${selYear}-W${String(selWeek).padStart(2, "0")}`;
    } else {
      payload = { year: selMYear, month: selMonth };
      expectedKey = `${selMYear}-${String(selMonth).padStart(2, "0")}`;
    }

    try {
      const fn = httpsCallable(functions, CF_FN[category][tab]);
      const result = await fn(payload);
      const data = result.data as {
        success?: boolean;
        periodKey?: string;
        restaurantCount?: number;
        totalOrders?: number;
        totalGrossRevenue?: number;
        message?: string;
      };

      const periodKey = data.periodKey || expectedKey;

      setCalcMsg({
        ok: true,
        text: data.message
          ? data.message
          : `${data.restaurantCount || 0} restoran · ${fmtCount(data.totalOrders || 0)} sipariş · ${fmt(data.totalGrossRevenue || 0)}`,
      });

      // Refresh history list
      histCursorRef.current = null;
      await loadHistPage(tab, true);

      // Auto-select the freshly calculated period
      selectPeriod(periodKey);
    } catch (err: unknown) {
      const msg = (err as { message?: string })?.message || "Hesaplama başarısız oldu.";
      setCalcMsg({ ok: false, text: msg });
    } finally {
      setCalcBusy(false);
    }
  }, [tab, category, selDate, selYear, selWeek, selMYear, selMonth, loadHistPage, selectPeriod]);

  // ─── Render: auth states ──────────────────────────────────────────────────

  if (authState === "loading") {
    return (
      <div className="h-screen flex items-center justify-center bg-gray-50">
        <div className="flex flex-col items-center gap-3">
          <div className="w-8 h-8 border-[3px] border-orange-200 border-t-orange-500 rounded-full animate-spin" />
          <p className="text-[12px] text-gray-400 font-medium">Yükleniyor...</p>
        </div>
      </div>
    );
  }

  if (authState === "denied") {
    return (
      <div className="h-screen flex items-center justify-center bg-gray-50 px-4">
        <div className="text-center max-w-sm">
          <div className="w-14 h-14 bg-red-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <WifiOff className="w-6 h-6 text-red-400" />
          </div>
          <h2 className="text-base font-bold text-gray-900 mb-1.5">Erişim Reddedildi</h2>
          <p className="text-[13px] text-gray-500 leading-relaxed">
            Bu sayfaya erişmek için{" "}
            <code className="bg-gray-100 px-1 rounded text-xs">isAdmin</code> veya{" "}
            <code className="bg-gray-100 px-1 rounded text-xs">masterCourier</code>{" "}
            yetkisine ihtiyacınız var.
          </p>
        </div>
      </div>
    );
  }

  // ─── Render: main layout ──────────────────────────────────────────────────

  const years = yearRange();
  const restTotalPages = Math.ceil(allRests.length / REST_UI_PAGE);
  const restSlice = allRests.slice(restPage * REST_UI_PAGE, (restPage + 1) * REST_UI_PAGE);

  return (
    <div className="h-[100dvh] pt-[55px] flex flex-col bg-gray-50 overflow-hidden">

      {/* ── Page header + tabs ───────────────────────────────────────────── */}
      <div className="flex-shrink-0 bg-white border-b border-gray-100 px-4 sm:px-6">
        <div className="flex items-center py-3">
          <div className="flex items-center gap-2">
            <button
              onClick={() => router.back()}
              className="w-8 h-8 bg-gray-100 hover:bg-gray-200 rounded-xl flex items-center justify-center transition-colors"
              title="Geri"
            >
              <ChevronLeft className="w-4 h-4 text-gray-600" />
            </button>
            <div className="w-8 h-8 bg-orange-50 rounded-xl flex items-center justify-center">
              <UtensilsCrossed className="w-4 h-4 text-orange-500" />
            </div>
            <div>
              <h1 className="text-[15px] font-bold text-gray-900 leading-tight">Muhasebe</h1>
              <p className="text-[10px] text-gray-400">Günlük · Haftalık · Aylık satış analizi</p>
            </div>
          </div>

          {/* Category tabs */}
          <div className="flex bg-gray-100 rounded-xl p-0.5 ml-3">
            {(["yemek", "market"] as CategoryType[]).map((c) => {
              const labels: Record<CategoryType, string> = {
                yemek: "Yemek",
                market: "Market",
              };
              return (
                <button
                  key={c}
                  onClick={() => setCategory(c)}
                  className={`px-4 py-1.5 text-[12px] font-semibold rounded-lg transition-all ${
                    category === c
                      ? "bg-white text-orange-600 shadow-sm"
                      : "text-gray-400 hover:text-gray-600"
                  }`}
                >
                  {labels[c]}
                </button>
              );
            })}
          </div>
        </div>

        {/* Period tabs */}
        <div className="flex gap-1 pb-0">
          {(["daily", "weekly", "monthly"] as PeriodType[]).map((t) => {
            const labels: Record<PeriodType, string> = {
              daily: "Günlük",
              weekly: "Haftalık",
              monthly: "Aylık",
            };
            return (
              <button
                key={t}
                onClick={() => setTab(t)}
                className={`px-4 py-2.5 text-[12px] font-semibold border-b-2 transition-all ${
                  tab === t
                    ? "border-orange-500 text-orange-600"
                    : "border-transparent text-gray-400 hover:text-gray-600 hover:border-gray-200"
                }`}
              >
                {labels[t]}
              </button>
            );
          })}
        </div>
      </div>

      {/* ── Body ────────────────────────────────────────────────────────── */}
      <div className="flex-1 overflow-hidden grid grid-cols-1 md:grid-cols-[340px_1fr]">

        {/* ── Left panel ──────────────────────────────────────────────── */}
        <div className="overflow-y-auto border-r border-gray-100 bg-white">
          <div className="p-4 space-y-4">

            {/* ── Calculate card ──────────────────────────────────────── */}
            <div className="bg-gray-50 border border-gray-100 rounded-2xl p-4">
              <p className="text-[11px] font-bold text-gray-500 uppercase tracking-widest mb-3">
                Hesapla
              </p>

              {/* Date inputs */}
              <div className="space-y-2 mb-3">
              {tab === "daily" && (
  <div>
    <label className="text-[10px] font-semibold text-gray-400 block mb-1">
