export default function MasterCourierDashboardPage() {
  // ── Auth ─────────────────────────────────────────────────────────────────
  const [authState, setAuthState] = useState<"loading" | "allowed" | "denied">(
    "loading",
  );

  // ── Raw data ─────────────────────────────────────────────────────────────
  const [courierProfiles, setCourierProfiles] = useState<
    Map<string, CourierProfile>
  >(new Map());
  const [activeOrders, setActiveOrders] = useState<Map<string, ActiveOrder[]>>(
    new Map(),
  );
  const [dailyStats, setDailyStats] = useState<Map<string, CourierStats>>(
    new Map(),
  );

  // ── UI state ──────────────────────────────────────────────────────────────
  const [selectedCourierId, setSelectedCourierId] = useState<string | null>(
    null,
  );
  const [searchQuery, setSearchQuery] = useState("");
  const [hiddenCouriers, setHiddenCouriers] = useState<Set<string>>(new Set());
  const [sidebarOpen, setSidebarOpen] = useState(true);
  const [mapsLoaded, setMapsLoaded] = useState(false);

  const [sessionKey, setSessionKey] = useState(0);

  // ── Assignment state ──────────────────────────────────────────────────────
  const [selectedPoolOrderId, setSelectedPoolOrderId] = useState<string | null>(
    null,
  );
  const [assignBusy, setAssignBusy] = useState(false);
  const [unassigningOrderId, setUnassigningOrderId] = useState<string | null>(
    null,
  );
  const [assignToast, setAssignToast] = useState<{
    ok: boolean;
    text: string;
  } | null>(null);

  // Refs so map marker closures can read latest values
  const selectedPoolOrderRef = useRef<{
    id: string;
    collection: OrderCollection;
  } | null>(null);
  const couriersRef = useRef<Map<string, Courier>>(new Map());

  // ── Bottom bar tabs ───────────────────────────────────────────────────────
  const [orderTab, setOrderTab] = useState<OrderCollection>("orders-food");
  const [foodSubtab, setFoodSubtab] = useState<FoodPoolStatus>("ready");
  const [marketSubtab, setMarketSubtab] = useState<MarketPoolStatus>("pending");

  const activeSubStatus: string =
    orderTab === "orders-food" ? foodSubtab : marketSubtab;

  const isPoolTab =
    (orderTab === "orders-food" && foodSubtab === "ready") ||
    (orderTab === "orders-market" && marketSubtab === "pending");

  useEffect(() => {
    // Reset selection when switching tabs
    setSelectedPoolOrderId(null);
  }, [orderTab, foodSubtab, marketSubtab]);

  // ── Pool orders (current tab) ─────────────────────────────────────────────
  const [poolOrders, setPoolOrders] = useState<PoolOrder[]>([]);
  const [poolPage, setPoolPage] = useState(0);
  const [poolHasMore, setPoolHasMore] = useState(false);
  const [poolLoading, setPoolLoading] = useState(false);
  const poolCursorsRef = useRef<(QueryDocumentSnapshot<DocumentData> | null)[]>(
    [null],
  );

  // ── Map refs ──────────────────────────────────────────────────────────────
  const mapDivRef = useRef<HTMLDivElement>(null);
  const mapRef = useRef<google.maps.Map | null>(null);
  const mapManagerRef = useRef<CourierMapManager | null>(null);
  const orderSignaturesRef = useRef<Map<string, string>>(new Map());

  // ── RTDB: courier locations ───────────────────────────────────────────────
  const courierLocations = useCourierLocations(authState === "allowed");

  // ── Profile fetch dedup ───────────────────────────────────────────────────
  const fetchedUidsRef = useRef<Set<string>>(new Set());

  // ── Derived: couriers ─────────────────────────────────────────────────────
  const couriers = useMemo<Map<string, Courier>>(() => {
    const result = new Map<string, Courier>();
    for (const [uid] of courierLocations) {
      const profile = courierProfiles.get(uid) ?? {
        uid,
        displayName: "Courier",
        email: "",
      };
      result.set(uid, {
        uid,
        profile,
        location: courierLocations.get(uid) ?? null,
        activeOrders: activeOrders.get(uid) ?? [],
        todayStats: dailyStats.get(uid) ?? {
          deliveredCount: 0,
          foodDeliveredCount: 0,
          marketDeliveredCount: 0,
          totalRevenue: 0,
          foodRevenue: 0,
          marketRevenue: 0,
          totalDeliveryTimeMs: 0,
        },
      });
    }
    return result;
  }, [courierLocations, courierProfiles, activeOrders, dailyStats]);

  useEffect(() => {
    couriersRef.current = couriers;
  }, [couriers]);

  const allCouriersArr = useMemo(
    () => Array.from(couriers.values()),
    [couriers],
  );
  // ── Assignment logic ──────────────────────────────────────────────────────
  // Writes a `courier_actions` doc which the processCourierAction Firestore
  // trigger picks up and atomically transitions the order into the `assigned`
  // state. We subscribe to the action doc to surface completion/failure..

  const assignOrderToCourier = useCallback(
    async (
      orderId: string,
      orderCollection: OrderCollection,
      courierId: string,
    ) => {
      const courierName =
        couriersRef.current.get(courierId)?.profile.displayName || "Kurye";
      setAssignBusy(true);

      const actionRef = doc(collection(db, "courier_actions"));

      let unsub: (() => void) | null = null;
      let settled = false;
      const finish = (ok: boolean, text: string) => {
        if (settled) return;
        settled = true;
        if (unsub) unsub();
        setAssignBusy(false);
        if (ok) setSelectedPoolOrderId(null);
        setAssignToast({ ok, text });
      };

      unsub = onSnapshot(
        actionRef,
        (snap) => {
          const d = snap.data() as
            | { status?: string; error?: string }
            | undefined;
          if (!d) return;
          if (d.status === "completed") {
            finish(true, `"${courierName}" üzerine atandı`);
          } else if (d.status === "failed") {
            const msg =
              d.error === "already_taken"
                ? "Bu sipariş zaten başka bir kurye tarafından alındı"
                : d.error === "Order not found"
                  ? "Sipariş bulunamadı"
                  : "Atama başarısız — tekrar deneyin";
            finish(false, msg);
          }
        },
        (err) => {
          console.error("[Assign] Snapshot error:", err);
          finish(false, "Atama başarısız — tekrar deneyin");
        },
      );

      try {
        await setDoc(actionRef, {
          type: "assign",
          collection: orderCollection,
          orderId,
          courierId,
          courierName,
          assignedBy: "master",
          status: "pending",
          createdAt: serverTimestamp(),
        });
      } catch (err) {
        console.error("[Assign] Write error:", err);
        finish(false, "Atama başarısız — tekrar deneyin");
        return;
      }

      // Safety timeout in case trigger never responds
      setTimeout(() => {
        if (!settled) finish(false, "Zaman aşımı — tekrar deneyin");
      }, 15000);
    },
    [],
  );

  // ── Unassignment logic ────────────────────────────────────────────────────
  // Writes a `courier_actions` doc with type: 'unassign'. The backend trigger
  // reverts the order to `accepted` (food) or `pending` (market) and clears
  // the courier assignment atomically.
  const unassignOrderFromCourier = useCallback(
    async (order: ActiveOrder, courierId: string, courierName: string) => {
      if (
        !window.confirm(
          `"${courierName}" kuryesinden bu siparişin atamasını kaldırmak istediğinize emin misiniz?`,
        )
      ) {
        return;
      }

      setUnassigningOrderId(order.id);
      const actionRef = doc(collection(db, "courier_actions"));

      let unsub: (() => void) | null = null;
      let settled = false;
      const finish = (ok: boolean, text: string) => {
        if (settled) return;
        settled = true;
        if (unsub) unsub();
        setUnassigningOrderId(null);
        setAssignToast({ ok, text });
      };

      unsub = onSnapshot(
        actionRef,
        (snap) => {
          const d = snap.data() as
            | { status?: string; error?: string }
            | undefined;
          if (!d) return;
          if (d.status === "completed") {
            finish(true, "Atama kaldırıldı");
          } else if (d.status === "failed") {
            const msg =
              d.error === "Order not found"
                ? "Sipariş bulunamadı"
                : "Atama kaldırma başarısız — tekrar deneyin";
            finish(false, msg);
          }
        },
        (err) => {
          console.error("[Unassign] Snapshot error:", err);
          finish(false, "Atama kaldırma başarısız — tekrar deneyin");
        },
      );

      try {
        await setDoc(actionRef, {
          type: "unassign",
          collection: order.collection,
          orderId: order.id,
          courierId,
          courierName,
          unassignedBy: "master",
          status: "pending",
          createdAt: serverTimestamp(),
        });
      } catch (err) {
        console.error("[Unassign] Write error:", err);
        finish(false, "Atama kaldırma başarısız — tekrar deneyin");
        return;
      }

      setTimeout(() => {
        if (!settled) finish(false, "Zaman aşımı — tekrar deneyin");
      }, 15000);
    },
    [],
  );

  // ── Toast auto-dismiss ────────────────────────────────────────────────────
  useEffect(() => {
    if (!assignToast) return;
    const t = setTimeout(() => setAssignToast(null), 3500);
    return () => clearTimeout(t);
  }, [assignToast]);

  // ── Auth ──────────────────────────────────────────────────────────────────
  useEffect(() => {
    return onIdTokenChanged(auth, async (user) => {
      if (!user) {
        setAuthState("denied");
        return;
      }
      try {
        const snap = await getDoc(doc(db, "users", user.uid));
        if (snap.data()?.masterCourier === true) {
          setAuthState("allowed");
          setSessionKey((k) => k + 1);
        } else {
          setAuthState("denied");
        }
      } catch {
        setAuthState("denied");
      }
    });
  }, []);

  // ── Google Maps ───────────────────────────────────────────────────────────
  useEffect(() => {
    if (authState !== "allowed" || typeof window === "undefined") return;
    if (window.google?.maps) {
      setMapsLoaded(true);
      return;
    }
    window.__initGoogleMaps = () => setMapsLoaded(true);
    const s = document.createElement("script");
    s.src = `https://maps.googleapis.com/maps/api/js?key=${MAPS_API_KEY}&callback=__initGoogleMaps&libraries=geometry`;
    s.async = true;
    s.defer = true;
    document.head.appendChild(s);
    return () => {
      delete window.__initGoogleMaps;
    };
  }, [authState]);

  useEffect(() => {
    if (!mapsLoaded || !mapDivRef.current || mapRef.current) return;
    const map = new window.google.maps.Map(mapDivRef.current, {
      center: CYPRUS_CENTER,
      zoom: 11,
      disableDefaultUI: true,
      zoomControl: true,
      zoomControlOptions: {
        position: window.google.maps.ControlPosition.RIGHT_BOTTOM,
      },
      styles: [
        { featureType: "poi", stylers: [{ visibility: "off" }] },
        { featureType: "transit", stylers: [{ visibility: "simplified" }] },
        { elementType: "geometry", stylers: [{ color: "#f8f8f8" }] },
        { elementType: "labels.text.fill", stylers: [{ color: "#717171" }] },
        { elementType: "labels.text.stroke", stylers: [{ color: "#f8f8f8" }] },
        {
          featureType: "road",
          elementType: "geometry",
          stylers: [{ color: "#ffffff" }],
        },
        {
          featureType: "road.highway",
          elementType: "geometry",
          stylers: [{ color: "#e8e8e8" }],
        },
        {
          featureType: "road.arterial",
          elementType: "geometry",
          stylers: [{ color: "#eeeeee" }],
        },
        {
          featureType: "water",
          elementType: "geometry",
          stylers: [{ color: "#d4e6f1" }],
        },
        {
          featureType: "landscape",
          elementType: "geometry",
          stylers: [{ color: "#f0f0f0" }],
        },
      ],
    });
    mapRef.current = map;

    // ◀ NEW: Create the map manager
    mapManagerRef.current = new CourierMapManager(map, (uid) => {
      const pending = selectedPoolOrderRef.current;
      if (pending) {
        assignOrderToCourier(pending.id, pending.collection, uid);
      } else {
        setSelectedCourierId((prev) => (prev === uid ? null : uid));
      }
    });

    return () => {
      mapManagerRef.current?.destroy();
      mapManagerRef.current = null;
    };
  }, [mapsLoaded, assignOrderToCourier]);

  // ── Fetch profiles ────────────────────────────────────────────────────────
  useEffect(() => {
    const unknownUids = Array.from(courierLocations.keys()).filter(
      (uid) => !fetchedUidsRef.current.has(uid),
    );
    if (unknownUids.length === 0) return;
    unknownUids.forEach((uid) => fetchedUidsRef.current.add(uid));
    Promise.all(
      unknownUids.map(async (uid) => {
        try {
          const snap = await getDoc(doc(db, "users", uid));
          if (snap.exists()) {
            const d = snap.data() as {
              displayName?: string;
              name?: string;
              email?: string;
            };
            return {
              uid,
              displayName: d.displayName || d.name || "Courier",
              email: d.email || "",
            };
          }
        } catch {
          /* silent */
        }
        return { uid, displayName: "Courier", email: "" };
      }),
    ).then((profiles) => {
      setCourierProfiles((prev) => {
        const next = new Map(prev);
        profiles.forEach((p) => next.set(p.uid, p));
        return next;
      });
    });
  }, [courierLocations]);

  // ── Firestore: active orders (both collections, courier-owned states) ────
  // Under the new lifecycle the sidebar shows every order that belongs to a
  // courier — i.e. status ∈ {assigned, out_for_delivery}. We merge results
  // from orders-food and orders-market into a single map keyed by courier id.
  useEffect(() => {
    if (authState !== "allowed") return;

    const foodMap = new Map<string, ActiveOrder[]>();
    const marketMap = new Map<string, ActiveOrder[]>();

    const mergeAndSet = () => {
      const merged = new Map<string, ActiveOrder[]>();
      for (const [uid, list] of foodMap) merged.set(uid, [...list]);
      for (const [uid, list] of marketMap) {
        const existing = merged.get(uid) ?? [];
        merged.set(uid, [...existing, ...list]);
      }
      setActiveOrders(merged);
    };

    const parseOrder = (
      d: QueryDocumentSnapshot<DocumentData>,
      orderCollection: OrderCollection,
    ): ActiveOrder | null => {
      const data = d.data();
      if (!data.cargoUserId) return null;
      const isMarket = orderCollection === "orders-market";
      const loc = data.deliveryAddress?.location;
      // Map market's marketLat/Lng/Name into the common restaurant* fields so
      // route logic stays collection-agnostic (same pattern as courier app).
      const pickupLat = isMarket
        ? (data.marketLat as number | undefined)
        : (data.restaurantLat as number | undefined);
      const pickupLng = isMarket
        ? (data.marketLng as number | undefined)
        : (data.restaurantLng as number | undefined);
      const pickupName = isMarket
        ? (data.marketName as string) || "Market"
        : (data.restaurantName as string) || "—";
      return {
        id: d.id,
        collection: orderCollection,
        restaurantName: pickupName,
        restaurantLat: typeof pickupLat === "number" ? pickupLat : null,
        restaurantLng: typeof pickupLng === "number" ? pickupLng : null,
        buyerName: (data.buyerName as string) || "—",
        totalPrice: (data.totalPrice as number) || 0,
        currency: (data.currency as string) || "TL",
        isPaid: (data.isPaid as boolean) || false,
        assignedAt: (data.assignedAt as Timestamp) || null,
        pickedUpAt: (data.pickedUpAt as Timestamp) || null,
        status: (data.status as string) || "",
        items: Array.isArray(data.items)
          ? (data.items as { name?: string; quantity?: number }[]).map(
              (item) => ({
                name: (item.name as string) || "—",
                quantity: (item.quantity as number) || 1,
              }),
            )
          : [],
        deliveryAddress: data.deliveryAddress
          ? {
              addressLine1: (data.deliveryAddress.addressLine1 as string) || "",
              city: (data.deliveryAddress.city as string) || "",
              location:
                loc &&
                typeof loc.latitude === "number" &&
                typeof loc.longitude === "number"
                  ? { latitude: loc.latitude, longitude: loc.longitude }
                  : null,
            }
          : null,
      };
    };

    const subscribe = (
      orderCollection: OrderCollection,
      target: Map<string, ActiveOrder[]>,
    ) => {
      // Time floor: ignore in-flight orders older than 12h. Anything older is
      // almost certainly stuck — it's still visible in the bottom bar's
      // assigned / out_for_delivery sub-tab for triage, just not streamed
      // into the live sidebar + map routes.
      const cutoff = Timestamp.fromMillis(Date.now() - 12 * 60 * 60 * 1000);
      const q = query(
        collection(db, orderCollection),
        where("status", "in", ["assigned", "out_for_delivery"]),
        where("updatedAt", ">=", cutoff),
      );
      return onSnapshot(q, (snap) => {
        target.clear();
        snap.docs.forEach((d) => {
          const order = parseOrder(d, orderCollection);
          if (!order) return;
          const cargoUid = (d.data().cargoUserId as string) || "";
          if (!cargoUid) return;
          const existing = target.get(cargoUid) ?? [];
          target.set(cargoUid, [...existing, order]);
        });
        mergeAndSet();
      });
    };

    const unsubFood = subscribe("orders-food", foodMap);
    const unsubMarket = subscribe("orders-market", marketMap);
    return () => {
      unsubFood();
      unsubMarket();
    };
  }, [authState, sessionKey]);

  // ── Daily stats ───────────────────────────────────────────────────────────
  const fetchDailyStats = useCallback(async (uids: string[]) => {
    if (uids.length === 0) return;
    const today = getTodayKey();
    const results = await Promise.allSettled(
      uids.map(async (uid) => {
        const snap = await getDoc(
          doc(db, "courier_daily_stats", `${uid}_${today}`),
        );
        if (snap.exists()) {
          const d = snap.data() as {
            deliveredCount?: number;
            foodDeliveredCount?: number;
            marketDeliveredCount?: number;
            totalRevenue?: number;
            foodRevenue?: number;
            marketRevenue?: number;
            totalDeliveryTimeMs?: number;
          };
          return {
            uid,
            stats: {
              deliveredCount: d.deliveredCount ?? 0,
              foodDeliveredCount: d.foodDeliveredCount ?? 0,
              marketDeliveredCount: d.marketDeliveredCount ?? 0,
              totalRevenue: d.totalRevenue ?? 0,
              foodRevenue: d.foodRevenue ?? 0,
              marketRevenue: d.marketRevenue ?? 0,
              totalDeliveryTimeMs: d.totalDeliveryTimeMs ?? 0,
            },
          };
        }
        return {
          uid,
          stats: {
            deliveredCount: 0,
            foodDeliveredCount: 0,
            marketDeliveredCount: 0,
            totalRevenue: 0,
            foodRevenue: 0,
            marketRevenue: 0,
            totalDeliveryTimeMs: 0,
          },
        };
      }),
    );
    setDailyStats((prev) => {
      const next = new Map(prev);
      results.forEach((r) => {
        if (r.status === "fulfilled") next.set(r.value.uid, r.value.stats);
      });
      return next;
    });
  }, []);

  const fetchCourierRoute = useCallback(
    async (
      courier: Courier,
      courierPos: google.maps.LatLng,
      signal?: AbortSignal,
    ) => {
      const orders = courier.activeOrders;
      if (orders.length === 0) {
        mapManagerRef.current?.routePaths.delete(courier.uid);
        mapManagerRef.current?.updateRoutes();
        return;
      }

      const toLatLng = (lat: number, lng: number) =>
        new window.google.maps.LatLng(lat, lng);

      const dist = (a: google.maps.LatLng, b: google.maps.LatLng) =>
        window.google.maps.geometry.spherical.computeDistanceBetween(a, b);

      // ── Build pickup/delivery stop pairs ─────────────────────────
      interface Stop {
        latLng: google.maps.LatLng;
        orderId: string;
        type: "pickup" | "delivery";
      }

      const stops: Stop[] = [];
      // Orders that are already `out_for_delivery` have been picked up — their
      // pickup stop is skipped, and the nearest-neighbor loop treats them as
      // already picked up so the delivery stop is reachable immediately.
      const alreadyPickedUp = new Set<string>();

      for (const order of orders) {
        const isAssigned = order.status === "assigned";
        if (isAssigned && order.restaurantLat && order.restaurantLng) {
          stops.push({
            latLng: toLatLng(order.restaurantLat, order.restaurantLng),
            orderId: order.id,
            type: "pickup",
          });
        } else {
          alreadyPickedUp.add(order.id);
        }
        if (order.deliveryAddress?.location) {
          stops.push({
            latLng: toLatLng(
              order.deliveryAddress.location.latitude,
              order.deliveryAddress.location.longitude,
            ),
            orderId: order.id,
            type: "delivery",
          });
        }
      }

      if (stops.length === 0) {
        mapManagerRef.current?.routePaths.delete(courier.uid);
        mapManagerRef.current?.updateRoutes();
        return;
      }

      // ── Nearest-neighbor with pickup-before-delivery constraint ──
      const ordered: Stop[] = [];
      const visited = new Set<number>();
      const pickedUp = new Set<string>(alreadyPickedUp);
      let current = courierPos;

      while (ordered.length < stops.length) {
        let bestIdx = -1;
        let bestDist = Infinity;

        for (let i = 0; i < stops.length; i++) {
          if (visited.has(i)) continue;
          const stop = stops[i];
          if (stop.type === "delivery" && !pickedUp.has(stop.orderId)) continue;

          const d = dist(current, stop.latLng);
          if (d < bestDist) {
            bestDist = d;
            bestIdx = i;
          }
        }

        if (bestIdx === -1) break;

        const chosen = stops[bestIdx];
        ordered.push(chosen);
        visited.add(bestIdx);
        current = chosen.latLng;

        if (chosen.type === "pickup") {
          pickedUp.add(chosen.orderId);
        }
      }

      if (ordered.length === 0) return;

      // ── OSRM route with ETA ─────────────────────────────────────
      try {
        const allStops = [courierPos, ...ordered.map((s) => s.latLng)];
        const result = await fetchRouteOSRM(allStops, signal);
        if (signal?.aborted) return;

        const mgr = mapManagerRef.current;
        if (result.path.length > 0 && mgr) {
          mgr.routePaths.set(courier.uid, result.path);

          let cumulativeSec = 0;
          ordered.forEach((stop, i) => {
            cumulativeSec += result.legDurations[i] ?? 0;
            if (stop.type === "delivery") {
              mgr.orderEtas.set(stop.orderId, {
                etaMin: Math.round(cumulativeSec / 60),
                distKm: +(result.totalDistanceM / 1000).toFixed(1),
              });
            }
          });

          mgr.updateRoutes();
        } else if (mgr) {
          mgr.routePaths.delete(courier.uid);
          mgr.updateRoutes();
        }
      } catch (err) {
        console.warn(`[Route] OSRM failed for ${courier.uid}:`, err);
        mapManagerRef.current?.routePaths.delete(courier.uid);
      }
    },
    [],
  );

