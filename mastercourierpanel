  <span className="text-[10px] font-bold text-gray-400 uppercase text-right">Teslim</span>
  <span className="text-[10px] font-bold text-gray-400 uppercase text-right">Ciro</span>
  <span className="text-[10px] font-bold text-gray-400 uppercase text-right">Ort.</span>
  <span className="text-[10px] font-bold text-amber-500 uppercase text-right">Nakit</span>
  <span className="text-[10px] font-bold text-violet-500 uppercase text-right">Kart</span>
  <span className="text-[10px] font-bold text-blue-500 uppercase text-right">IBAN</span>
</div>

                      {/* Rows */}
                      {restSlice.map((rest, idx) => {
  const isExpanded = expandedRests.has(rest.restaurantId);
  return (
    <React.Fragment key={rest.restaurantId}>
      <div
        onClick={() => {
          setExpandedRests((prev) => {
            const next = new Set(prev);
            if (next.has(rest.restaurantId)) next.delete(rest.restaurantId);
            else next.add(rest.restaurantId);
            return next;
          });
        }}
        className={`grid grid-cols-[1fr_60px_60px_100px_80px_80px_80px_80px] gap-2 px-4 py-3 cursor-pointer select-none transition-colors ${
          idx > 0 ? "border-t border-gray-50" : ""
        } ${isExpanded ? "bg-orange-50/40" : "hover:bg-gray-50/70"}`}
      >
        <div className="min-w-0 flex items-center gap-2">
          <ChevronRight
            className={`w-3.5 h-3.5 flex-shrink-0 transition-transform ${
              isExpanded ? "rotate-90 text-orange-500" : "text-gray-300"
            }`}
          />
          <div className="min-w-0">
            <p className="text-[12px] font-semibold text-gray-900 truncate leading-tight">
              {rest.restaurantName || rest.restaurantId}
            </p>
            {rest.cancelledOrders > 0 && (
              <p className="text-[10px] text-red-400 leading-none mt-0.5">
                {rest.cancelledOrders} iptal
              </p>
            )}
          </div>
        </div>
        <p className="text-[12px] font-semibold text-gray-700 text-right self-center">
          {fmtCount(rest.totalOrders)}
        </p>
        <p className="text-[12px] font-semibold text-emerald-600 text-right self-center">
          {fmtCount(rest.completedOrders)}
        </p>
        <p className="text-[12px] font-bold text-gray-900 text-right self-center">
          {fmt(rest.grossRevenue)}
        </p>
        <p className="text-[11px] text-gray-500 text-right self-center">
          {fmt(rest.averageOrderValue)}
        </p>
        <p className="text-[11px] text-amber-600 font-semibold text-right self-center">
          {rest.paymentReceivedBreakdown?.cash?.amount
            ? fmt(rest.paymentReceivedBreakdown.cash.amount)
            : "—"}
        </p>
        <p className="text-[11px] text-violet-600 font-semibold text-right self-center">
          {rest.paymentReceivedBreakdown?.card?.amount
            ? fmt(rest.paymentReceivedBreakdown.card.amount)
            : "—"}
        </p>
        <p className="text-[11px] text-blue-600 font-semibold text-right self-center">
          {rest.paymentReceivedBreakdown?.iban?.amount
            ? fmt(rest.paymentReceivedBreakdown.iban.amount)
            : "—"}
        </p>
      </div>
      {isExpanded && (
        <div className="bg-gray-50/60 px-5 py-3 border-t border-gray-100">
          <p className="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2">
            En Çok Satan Ürünler
          </p>
          {rest.topItems && rest.topItems.length > 0 ? (
            <div className="space-y-1.5">
              {rest.topItems.map((item, i) => (
                <div key={item.name} className="flex items-center gap-3 text-[11px]">
                  <span className="w-5 text-gray-400 font-medium text-right">{i + 1}.</span>
                  <span className="flex-1 truncate text-gray-700 font-medium">{item.name}</span>
                  <span className="font-semibold text-gray-900 w-24 text-right">
                    {fmtCount(item.quantity)} adet
                  </span>
                  <span className="text-gray-400 w-24 text-right">{fmt(item.revenue)}</span>
                </div>
              ))}
            </div>
          ) : (
            <p className="text-[11px] text-gray-400 italic">Bu restoran için ürün verisi yok.</p>
          )}
        </div>
      )}
    </React.Fragment>
  );
})}
                    </div>

                    {/* Pagination */}
                    {restTotalPages > 1 && (
                      <div className="flex items-center justify-between mt-3">
                        <button
                          onClick={() => setRestPage((p) => Math.max(0, p - 1))}
                          disabled={restPage === 0}
                          className="flex items-center gap-1.5 px-3 py-1.5 rounded-xl border border-gray-200 text-[11px] font-medium text-gray-600 hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed transition-colors"
                        >
                          <ChevronLeft className="w-3.5 h-3.5" />
                          Önceki
                        </button>
                        <div className="flex items-center gap-2">
                          <span className="text-[11px] text-gray-400">
                            {restPage + 1} / {restTotalPages}
                          </span>
                          <span className="text-[10px] text-gray-300">
                            ({fmtCount(allRests.length)} restoran)
                          </span>
                        </div>
                        <button
                          onClick={() =>
                            setRestPage((p) => Math.min(restTotalPages - 1, p + 1))
                          }
                          disabled={(restPage + 1) * REST_UI_PAGE >= allRests.length}
                          className="flex items-center gap-1.5 px-3 py-1.5 rounded-xl border border-gray-200 text-[11px] font-medium text-gray-600 hover:bg-gray-50 disabled:opacity-40 disabled:cursor-not-allowed transition-colors"
                        >
                          Sonraki
                          <ChevronRight className="w-3.5 h-3.5" />
                        </button>
                      </div>
                    )}
                  </>
                )}
              </div>
              )}

              {/* Bottom spacer */}
              <div className="h-4" />
            </div>
          )}
        </div>
      </div>
    </div>
  );
}