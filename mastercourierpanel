};

const HIST_LIMIT = 20;
const REST_UI_PAGE = 12;

// ─── Helpers ──────────────────────────────────────────────────────────────────

function fmt(n: number): string {
  return n.toLocaleString("tr-TR", { maximumFractionDigits: 0 }) + " ₺";
}

function fmtCount(n: number): string {
  return n.toLocaleString("tr-TR");
}

function fmtTs(ts: Timestamp | null): string {
  if (!ts) return "—";
  return ts.toDate().toLocaleDateString("tr-TR", {
    day: "2-digit", month: "short", year: "numeric",
    hour: "2-digit", minute: "2-digit",
  });
}

function pLabel(type: PeriodType, key: string): string {
    if (type === "daily") {
      const [y, m, d] = key.split("-").map(Number);
      if (!y || !m || !d) return key;
      return new Date(y, m - 1, d).toLocaleDateString("tr-TR", {
        weekday: "long", day: "numeric", month: "long", year: "numeric",
      });
    }
    if (type === "weekly") {
      const parts = key.split("-W");
      const w = parseInt(parts[1] ?? "0");
      return `${parts[0]} yılı · ${w || "?"}. Hafta`;
    }
    const [y, m] = key.split("-").map(Number);
    const monthName = TR_MONTHS[m - 1];
    if (!monthName) return key; // ← prevents crash here too
    return `${monthName} ${y}`;
  }

function pLabelShort(type: PeriodType, key: string): string {
    if (type === "daily") {
      const [y, m, d] = key.split("-").map(Number);
      if (!y || !m || !d) return key;
      return new Date(y, m - 1, d).toLocaleDateString("tr-TR", {
        day: "numeric", month: "short", year: "numeric",
      });
    }
    if (type === "weekly") {
      const parts = key.split("-W");
      const w = parseInt(parts[1] ?? "0");
      return `${w || "?"}. Hafta`;
    }
    const [y, m] = key.split("-").map(Number);
    const monthName = TR_MONTHS[m - 1];
    if (!monthName) return key; // ← prevents the crash
    return `${monthName.slice(0, 3)} ${y}`;
  }

function getYesterday(): string {
  const d = new Date(Date.now() - 86_400_000);
  return [
    d.getFullYear(),
    String(d.getMonth() + 1).padStart(2, "0"),
    String(d.getDate()).padStart(2, "0"),
  ].join("-");
}

function getLastWeek(): { year: number; week: number } {
  const d = new Date(Date.now() - 7 * 86_400_000);
  const jan4 = new Date(d.getFullYear(), 0, 4);
  const dow = (jan4.getDay() + 6) % 7;
  const mon = new Date(jan4.getTime() - dow * 86_400_000);
  const week = Math.max(
    1,
    Math.min(53, 1 + Math.round((d.getTime() - mon.getTime()) / (7 * 86_400_000))),
  );
  return { year: d.getFullYear(), week };
}

function getLastMonth(): { year: number; month: number } {
  const d = new Date(new Date().getFullYear(), new Date().getMonth() - 1, 1);
  return { year: d.getFullYear(), month: d.getMonth() + 1 };
}

function yearRange(): number[] {
  const cur = new Date().getFullYear();
  const out: number[] = [];
  for (let y = 2024; y <= cur; y++) out.push(y);
  return out;
}

function completionRate(completed: number, total: number): string {
  if (!total) return "0%";
  return `${Math.round((completed / total) * 100)}%`;
}

